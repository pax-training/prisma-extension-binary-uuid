// Development + integration-test schema.
//
// Every UUID field uses `@default(dbgenerated("(UUID_TO_BIN(UUID(), 1))"))` so
// the generated Prisma Client types treat them as optional on create. At
// runtime, if the extension-equipped client sees a string UUID in `data.id`
// it converts to binary before the query hits the DB; if `data.id` is absent
// and no dbgenerated default were set, the extension auto-generates. Either
// path ends at the same binary value in storage.
//
// The published extension is schema-agnostic; this schema is only for dev +
// integration tests.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id         Bytes     @id @default(dbgenerated("(UUID_TO_BIN(UUID(), 1))")) @db.Binary(16)
  storageId  Bytes     @unique @default(dbgenerated("(UUID_TO_BIN(UUID(), 1))")) @db.Binary(16)
  email      String    @unique @db.VarChar(255)
  name       String?   @db.VarChar(255)
  avatar     Bytes?
  companyId  Bytes?    @db.Binary(16)
  company    Company?  @relation(fields: [companyId], references: [id])
  posts      Post[]
  profile    Profile?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt
}

model Company {
  id         Bytes     @id @default(dbgenerated("(UUID_TO_BIN(UUID(), 1))")) @db.Binary(16)
  name       String    @db.VarChar(255)
  users      User[]
  createdAt  DateTime  @default(now())
}

model Post {
  id         Bytes     @id @default(dbgenerated("(UUID_TO_BIN(UUID(), 1))")) @db.Binary(16)
  title      String    @db.VarChar(255)
  content    String?   @db.Text
  published  Boolean   @default(false)
  authorId   Bytes     @db.Binary(16)
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tags       PostTag[]
  createdAt  DateTime  @default(now())

  @@index([authorId])
  @@index([authorId, published])
}

model Profile {
  id      Bytes   @id @default(dbgenerated("(UUID_TO_BIN(UUID(), 1))")) @db.Binary(16)
  userId  Bytes   @unique @db.Binary(16)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio     String? @db.Text
}

model Tag {
  id    Bytes     @id @default(dbgenerated("(UUID_TO_BIN(UUID(), 1))")) @db.Binary(16)
  name  String    @unique @db.VarChar(100)
  posts PostTag[]
}

model PostTag {
  postId Bytes @db.Binary(16)
  tagId  Bytes @db.Binary(16)
  post   Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}
